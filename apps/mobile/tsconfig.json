{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "jsx": "react-native",
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*":                  ["./src/*"],
      "@wellpath/constants":  ["../../packages/constants/src/index.ts"],
      "@wellpath/types":      ["../../packages/types/src/index.ts"],
      "@wellpath/api-client": ["../../packages/api-client/src/index.ts"],
      "@wellpath/store":      ["../../packages/store/src/index.ts"]
    }
  },
  "include": ["app", "src", "expo-env.d.ts", "nativewind-env.d.ts"],
  "exclude": ["node_modules"]
}
